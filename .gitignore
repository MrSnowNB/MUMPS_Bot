# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
*.egg

# Tool output (regenerated by pipeline)
output/*.json
output/*.py
output/*.py.md
!output/README.md
!output/.gitkeep

# Logs (append-only, machine-specific)
logs/*.jsonl
logs/.session
!logs/README.md
!logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Virtual environments
.venv/
venv/
env/

# Fix script (one-time use)
fix_all.py

# Vendor — compiled grammar (built locally, not committed)
vendor/tree-sitter-mumps/
vendor/*.so
!vendor/README.md
